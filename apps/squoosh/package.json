{
  "name": "@squoosh-kit/squoosh",
  "private": true,
  "homepage": "http://squoosh-kit.dev",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "pages:deploy": "wrangler pages deploy dist",
    "pages:dev": "wrangler pages dev dist"
  },
  "dependencies": {
    "@squoosh-kit/core": "workspace:*",
    "@squoosh-kit/vite-plugin": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.11",
    "typescript": "~6.0.3",
    "vite": "^7.3.1",
    "wrangler": "^4.28.0"
  }
}
